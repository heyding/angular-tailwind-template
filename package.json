{
  "name": "angular-tailwind-template",
  "version": "1.0.0",
  "description": "D-Stack Ready Angular 19 Enterprise Template with Tailwind CSS, NgRx, DSGVO compliance, and 25+ production-ready components for German government and public administration",
  "keywords": [
    "angular",
    "angular-19",
    "d-stack",
    "dstack",
    "deutschland-stack",
    "tailwind",
    "tailwindcss",
    "ngrx",
    "typescript",
    "enterprise-template",
    "dsgvo",
    "gdpr",
    "angular-template",
    "starter-template",
    "government",
    "public-administration",
    "dark-mode",
    "i18n",
    "authentication",
    "state-management"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/heyding/angular-tailwind-template.git"
  },
  "homepage": "https://github.com/heyding/angular-tailwind-template#readme",
  "bugs": {
    "url": "https://github.com/heyding/angular-tailwind-template/issues"
  },
  "author": "Tommy Heyding",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ci": "ng build --base-href /",
    "build:gh-pages": "ng build --base-href /angular-tailwind-template/",
    "openapi:generate": "ng-openapi-gen --config ng-openapi-gen.json",
    "openapi:clean": "rm -rf src/app/core/api/generated",
    "openapi:check": "npm run openapi:generate && git diff --exit-code -- src/app/core/api/generated",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=list,html",
    "lhci": "npm run build:ci && lhci autorun",
    "quality": "npm run e2e:ci && npm run lhci",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\"",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.2.18",
    "@angular/core": "^19.2.19",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@ngrx/effects": "^19.0.0",
    "@ngrx/schematics": "^19.0.0",
    "@ngrx/store": "^19.0.0",
    "@ngrx/store-devtools": "^19.0.0",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "ngrx-store-localstorage": "^19.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.53.2",
    "@angular-devkit/build-angular": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "19.2.19",
    "@types/jasmine": "^5.1.4",
    "@types/node": "^22.10.2",
    "autoprefixer": "^10.4.23",
    "husky": "^9.1.7",
    "http-server": "^14.1.1",
    "jasmine-core": "^5.5.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "lint-staged": "^16.2.7",
    "ng-openapi-gen": "^1.0.3",
    "postcss": "^8.4.49",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3"
  },
  "overrides": {
    "@angular/build": "19.2.22"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
